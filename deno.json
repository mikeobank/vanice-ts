{
  "name": "@vanice/vanice-pool",
  "version": "0.3.0",
  "license": "MIT",
  "exports": "./mod.ts",
  "imports": {
    "@vanice/types": "jsr:@vanice/types@^0.3.0"
  },
  "tasks": {
    "compile": "deno compile --allow-env --output vanice --include ./src/worker.ts ./src/main.ts",
    "bundle": "deno bundle src/worker.ts --outdir dist",
    "run": "deno run --allow-read --allow-env src/main.ts"
  }
}
